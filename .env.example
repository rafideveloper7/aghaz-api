# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Local: mongodb://localhost:27017/aghaz
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/aghaz
MONGODB_URI=mongodb://localhost:27017/aghaz

# JWT Secret (CHANGE THIS TO A STRONG RANDOM STRING)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ImageKit Configuration
# Sign up at https://imagekit.io to get these credentials
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# CORS Configuration
# Comma-separated list of allowed origins
CLIENT_URL=http://localhost:3001

# Optional: Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 // 15 minutes
RATE_LIMIT_MAX_REQUESTS=2 // Max 100 requests per window per IP
